let name = "Carv";
println("Welcome to Carv!");

class Point {
    x: int = 0
    y: int = 0
}

let point = new Point;
point.x = 10;
point.y = 20;
println("point created");

fn add(a: int, b: int) -> int {
    return a + b;
}

let sum = add(point.x, point.y);
println("sum:", sum);

